    "abstract": {
      "entries": [
        {
          "headingText": "ABSTRACT",
          "text": "This work presents a proposal for an automatic formatting engine for academic documents, driven by declarative institutional profiles. The approach eliminates hardcoded logic from rendering components, enabling new profiles to be created without code changes.",
          "keywords": ["automatic formatting", "academic documents", "institutional profiles"],
          "keywordsLabel": "Keywords:"
        },
        {
          "headingText": "RESUMEN",
          "text": "Este trabajo presenta una propuesta de motor de formateo automático de documentos académicos, orientado por perfiles institucionales declarativos. El enfoque elimina la lógica codificada de los componentes de renderizado.",
          "keywords": ["formateo automático", "documentos académicos", "perfiles institucionales"],
          "keywordsLabel": "Palabras clave:"
        }
      ]
